NODE_ENV=development
PORT=3344

# WhatsApp Cloud API
WHATSAPP_TOKEN=<access_token>
WHATSAPP_PHONE_NUMBER_ID=<phone_number_id>
WHATSAPP_VERIFY_TOKEN=<verify_token>
WHATSAPP_TEST_MODE=false
WHATSAPP_API_VERSION=v22.0

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=<user>
DB_PASSWORD=<password>
DB_NAME=wau_business

# AI Provider: openai | bedrock | none
AI_PROVIDER=none
OPENAI_API_KEY=<key>
OPENAI_MODEL=gpt-4o-mini
AWS_BEDROCK_REGION=us-east-1
AWS_BEDROCK_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0
AWS_BEDROCK_MAX_TOKENS=800

# Storage: local | s3
STORAGE_PROVIDER=local
AWS_S3_BUCKET=<bucket>
AWS_S3_REGION=<region>

# Transcription
AWS_TRANSCRIBE_REGION=eu-north-1
AWS_TRANSCRIBE_BUCKET=<bucket>
AWS_TRANSCRIBE_LANGUAGE_CODE=en-US

# Subscription
SUBSCRIPTION_ENABLED=false
