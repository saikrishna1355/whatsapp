{
  "name": "wau-backend",
  "version": "1.0.0",
  "description": "WAU Business Assistant - WhatsApp-first business recordkeeping platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --outDir dist",
    "build:sit": "tsc --outDir dist-sit",
    "build:uat": "tsc --outDir dist-uat",
    "build:live": "tsc --outDir dist-live",
    "start": "node dist/server.js",
    "start:sit": "env-cmd -f .env.sit node dist-sit/server.js",
    "start:uat": "env-cmd -f .env.uat node dist-uat/server.js",
    "start:live": "env-cmd -f .env.live node dist-live/server.js",
    "migrate": "knex migrate:latest --knexfile knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile knexfile.ts",
    "seed": "knex seed:run --knexfile knexfile.ts",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mysql2": "^3.11.0",
    "pdfkit": "^0.15.0",
    "pino": "^9.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.13.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "env-cmd": "^11.0.0",
    "eslint": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
